{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist"
  },
  "include": [
    "hardhat.config.ts",
    "test/**/*.ts",
    "deploy/**/*.ts",
    "ignition/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "app"]
}
