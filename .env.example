# Axi Environment Configuration
# Copy this to .env and fill in your values

# Sepolia RPC URL (get one from Alchemy, Infura, or similar)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployer private key (DO NOT commit this!)
DEPLOYER_PRIVATE_KEY=0x...

# Frontend
NEXT_PUBLIC_NOXSHIELD_ROUTER_ADDRESS=0x...
NEXT_PUBLIC_NOXSHIELD_VAULT_ADDRESS=0x...
NEXT_PUBLIC_INTENT_POOL_ADDRESS=0x...
NEXT_PUBLIC_CWETH_ADDRESS=0x...
NEXT_PUBLIC_CUSDC_ADDRESS=0x...
NEXT_PUBLIC_WETH_ADDRESS=0x...
NEXT_PUBLIC_USDC_ADDRESS=0x...
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
